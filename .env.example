# ---------- 大模型：DeepSeek（OpenAI 兼容 Chat Completions API）----------
# LangChain 使用 ChatOpenAI 客户端连接此类接口，并非绑定 OpenAI 官方。
DEEPSEEK_API_KEY=
# 一般无需带 /v1，程序会自动拼接
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat

# ---------- 高德（路径等）----------
AMAP_API_KEY=
AMAP_BYPASS_PROXY=true

# ---------- MySQL（注册登录与会话）----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=smart_cs_agent
MYSQL_UNIX_SOCKET=/tmp/mysql.sock

# ---------- 可选：其它 OpenAI 兼容厂商（仅当不使用 DeepSeek 时配置）----------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---------- Docker Compose（docker compose up 时）----------
# 容器内 MySQL 的 root 密码；应用连接也使用该密码（与 MYSQL_PASSWORD 建议相同）
# MYSQL_ROOT_PASSWORD=
# APP_PORT=8010
# 是否把容器 3306 映射到本机（调试/外部客户端用，可省略）
# MYSQL_PUBLISH_PORT=3306
